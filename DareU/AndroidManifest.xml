        <activity
            android:name="com.example.dareu.Friends"
            android:label="@string/title_activity_friends" >
        </activity>
        <activity
            android:name="com.example.dareu.More"
            android:label="@string/title_activity_more" >
        </activity>
        <activity
            android:name="com.example.dareu.GroupActivity"
            android:label="@string/title_activity_group" >
        </activity>
        <activity
            android:name="com.example.dareu.Group.Accepted"
            android:label="@string/title_activity_accepted" >
        </activity>
    </application>

</manifest>
